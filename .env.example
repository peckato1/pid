# Copy to .env and fill in

# Admin (superuser) — created by the postgres image itself
POSTGRES_USER=pid_admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres

# Application database + users — created by docker/postgres-init.sh on first init
APP_POSTGRES_DB=pid
APP_POSTGRES_RW_USER=pid_rw
APP_POSTGRES_RW_PASSWORD=changeme
APP_POSTGRES_RO_USER=pid_ro
APP_POSTGRES_RO_PASSWORD=changeme

# DATABASE_URL is assembled per-service in compose.yml from the credentials above.
# Passwords must not contain URL-reserved chars (: / @ ? #) — stick to alphanumerics.

GOLEMIO_API_KEY=

# Host path where downloaded GTFS zips are kept
GTFS_ARCHIVES_DIR=./gtfs_archives

COMPOSE_PROJECT_NAME=pid

# Image tag to run. Local dev: leave unset (defaults to "local", built from Dockerfile).
# Prod: set to "nightly" or a release tag like "v1" to pull from ghcr.io/peckato1/pid.
#TAG=nightly
