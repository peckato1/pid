# Copy to .env and fill in
POSTGRES_USER=pid
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pid

# Connection string used by the app (host = service name "postgis")
DATABASE_URL=postgresql+psycopg://pid:changeme@postgis:5432/pid

GOLEMIO_API_KEY=

# Host path where downloaded GTFS zips are kept
GTFS_ARCHIVES_DIR=./gtfs_archives

COMPOSE_PROJECT_NAME=pid

# Image tag to run. Local dev: leave unset (defaults to "local", built from Dockerfile).
# Prod: set to "nightly" or a release tag like "v1" to pull from ghcr.io/peckato1/pid.
#TAG=nightly
